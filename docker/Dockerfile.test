# Docker 测试镜像定义
# 用于验证 npm 包在不同环境下的完整性和功能可用性

# node:20-slim 自带 Node.js, npm, 和一个精简的 Debian 系统
FROM node:20-slim AS base

# 设置环境变量和时区
ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    SHELL=/bin/bash \
    PATH=/home/testuser/.local/bin:/home/testuser/bin:$PATH \
    UV_SYSTEM_PYTHON=1

# 设置时区
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 安装系统依赖（包含 uv 支持所需的工具）
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    tmux \
    && rm -rf /var/lib/apt/lists/*

# 创建非 root 用户
RUN useradd -m -s /bin/bash testuser && \
    mkdir -p /home/testuser/.local/bin /home/testuser/bin && \
    chown -R testuser:testuser /home/testuser

# 切换到 testuser
USER testuser
WORKDIR /home/testuser

# 安装 uv
ENV PATH=/home/testuser/.local/bin:$PATH
RUN curl -LsSf https://astral.sh/uv/install.sh | bash && \
    uv python install 3.11

# 安装 Claude CLI 和 Codex CLI（通过 npm 全局安装）
# 注意：不进行登录，仅安装二进制
USER root
RUN npm config set registry https://registry.npmmirror.com && \
    npm install -g @anthropic-ai/claude-code @openai/codex && \
    npm cache verify && \
    rm -rf /root/.npm

USER testuser

# 创建测试结果目录
RUN mkdir -p /home/testuser/test-results /home/testuser/test-results/npm-install

# 设置默认命令
CMD ["/bin/bash"]