# Docker 测试镜像定义
# 用于验证 npm 包在不同环境下的完整性和功能可用性

FROM ubuntu:22.04

# 环境变量
ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH=/home/testuser/.local/bin:/home/testuser/bin:$PATH

# 设置时区
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 安装系统依赖（先装 curl/ca-certificates，再通过 NodeSource 安装 Node.js 20）
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    tmux \
    curl \
    git \
    build-essential \
    libevent-dev \
    libncurses5-dev \
    libncursesw5-dev \
    bison \
    pkg-config \
    ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# 创建非 root 用户
RUN useradd -m -s /bin/bash testuser && \
    mkdir -p /home/testuser/.local/bin /home/testuser/bin && \
    chown -R testuser:testuser /home/testuser

# 切换到 testuser
USER testuser
WORKDIR /home/testuser

# 安装 uv（优先使用官方脚本）
RUN curl -LsSf https://astral.sh/uv/install.sh | sh || \
    pip3 install uv --break-system-packages || true

# 设置 uv 路径
ENV PATH=/home/testuser/.local/bin:$PATH

# 安装 Claude CLI 和 Codex CLI（通过 npm 全局安装）
# 注意：不进行登录，仅安装二进制
USER root
RUN npm install -g @anthropic-ai/claude-code @openai/codex
USER testuser

# 创建测试结果目录
RUN mkdir -p /home/testuser/test-results

# 设置默认命令
CMD ["/bin/bash"]
