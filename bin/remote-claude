#!/bin/sh
# remote-claude - Remote Claude 主命令入口（POSIX sh 兼容）

# 解析符号链接，兼容 macOS（不支持 readlink -f）
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    SELF_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    case "$SOURCE" in
        /*) ;;
        *) SOURCE="$SELF_DIR/$SOURCE" ;;
    esac
done
SELF_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_DIR="$(cd "$SELF_DIR/.." && pwd)"
STARTUP_DIR="${STARTUP_DIR:-$(pwd)}"
# 引入共享脚本（提供颜色定义、打印函数、uv 管理函数）
# _common.sh 末尾会自动调用 _lazy_init 进行初始化检查
. "$PROJECT_DIR/scripts/_common.sh"
_init_startup_dir
_require_startup_dir || exit 1

# log 子命令：查看最后启动的 session 日志
if [ "$1" = "log" ]; then
    LOG_DIR="/tmp/remote-claude"
    if [ -n "$2" ]; then
        # 指定 session 名，/ 和 . 替换为 _（与 _safe_filename 一致）
        SESSION_SAFE=$(echo "$2" | tr '/.' '__')
        LOG_FILE="$LOG_DIR/${SESSION_SAFE}_messages.log"
    else
        # 找最后启动的 session（按创建时间排序，排除 lark.pid）
        # 使用 uname 判断系统类型，兼容 POSIX sh
        if uname | grep -q Darwin; then
            # macOS: stat -f "%B" 返回创建时间（秒）
            LATEST_PID=$(ls "$LOG_DIR"/_*.pid 2>/dev/null | while read f; do
                stat -f "%B:%N" "$f" 2>/dev/null
            done | sort -rn | head -1 | cut -d: -f2)
        else
            # Linux: stat -c "%W" 返回创建时间（秒）
            LATEST_PID=$(ls "$LOG_DIR"/_*.pid 2>/dev/null | while read f; do
                stat -c "%W:%N" "$f" 2>/dev/null
            done | sort -rn | head -1 | cut -d: -f2)
        fi
        if [ -n "$LATEST_PID" ]; then
            SESSION_SAFE=$(basename "$LATEST_PID" .pid)
            LOG_FILE="$LOG_DIR/${SESSION_SAFE}_messages.log"
        fi
    fi

    if [ -z "$LOG_FILE" ] || [ ! -f "$LOG_FILE" ]; then
        echo "没有找到日志文件（请先启动一个会话）" >&2
        exit 1
    fi

    echo "📄 $LOG_FILE"
    exec tail -50f "$LOG_FILE"
fi

# lark 子命令：仅在真实执行管理动作时检查 .env，help 不应触发交互配置
if [ "$1" = "lark" ] && [ "${2:-}" != "--help" ] && [ "${2:-}" != "-h" ]; then
    sh "${PROJECT_DIR}/scripts/check-env.sh"
fi

# -h/--help：显示简明命令概览（在 shell 层处理，无需 Python 初始化）
case "${1:-}" in
    -h|--help)
        . "$PROJECT_DIR/scripts/_help.sh"
        _print_main_help
        exit 0
        ;;
esac

# 在启动目录执行入口点，保持调用方 cwd
cd "$STARTUP_DIR" || exit 1
_remote_claude_python "$@"
exit $?
