#!/bin/sh
# cl - 启动飞书客户端 + 以当前目录路径+时间戳为会话名启动 Claude（跳过权限确认）

# 解析符号链接，兼容 macOS（不支持 readlink -f）
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    SELF_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    case "$SOURCE" in /*) ;; *) SOURCE="$SELF_DIR/$SOURCE" ;; esac
done
SELF_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_DIR="$(cd "$SELF_DIR/.." && pwd)"
STARTUP_DIR="${STARTUP_DIR:-$(pwd)}"
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    export LAZY_INIT_DISABLE_AUTO_RUN=1
fi
. "$PROJECT_DIR/scripts/_common.sh"
_init_startup_dir
_require_startup_dir || exit 1

_remote_claude_shortcut_help_or_main "Claude" "--dangerously-skip-permissions --permission-mode=dontAsk" "$@"
