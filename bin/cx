#!/bin/sh
# cx - 启动飞书客户端 + 以当前目录路径+时间戳为会话名启动 Codex（跳过权限）

# 解析符号链接，兼容 macOS（不支持 readlink -f）
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    SELF_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    case "$SOURCE" in /*) ;; *) SOURCE="$SELF_DIR/$SOURCE" ;; esac
done
SELF_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_DIR="$(cd "$SELF_DIR/.." && pwd)"
STARTUP_DIR="${STARTUP_DIR:-$(pwd)}"
. "$PROJECT_DIR/scripts/_common.sh"
_init_startup_dir
_require_startup_dir || exit 1

# 飞书未配置时允许继续启动本地会话
REMOTE_CLAUDE_REQUIRE_FEISHU=0
export REMOTE_CLAUDE_REQUIRE_FEISHU
sh "$PROJECT_DIR/scripts/check-env.sh"

# help 参数应显示 start 用法，而不是启动会话
case "${1:-}" in
    -h|--help)
        exec "$PROJECT_DIR/bin/remote-claude" start --help --cli codex
        ;;
esac

# 在启动目录执行入口点，保持 session 名与 cwd 一致
cd "$STARTUP_DIR" || exit 1
if [ -f "$HOME/.remote-claude/.env" ]; then
    _remote_claude_python lark start
fi
_remote_claude_python start "${STARTUP_DIR}_$(date +%m%d_%H%M%S)" --cli codex --dangerously-bypass-approvals-and-sandbox "$@"
