{
  "name": "remote-claude",
  "version": "1.0.3",
  "description": "双端共享 Claude CLI 工具",
  "bin": {
    "remote-claude": "bin/remote-claude",
    "cla": "bin/cla",
    "cl": "bin/cl"
  },
  "scripts": {
    "preinstall": "bash scripts/preinstall.sh",
    "postinstall": "bash scripts/postinstall.sh"
  },
  "files": [
    "bin/",
    "scripts/*.sh",
    "scripts/*.py",
    "init.sh",
    "remote_claude.py",
    "server/*.py",
    "server/parsers/*.py",
    "client/*.py",
    "utils/*.py",
    "lark_client/__init__.py",
    "lark_client/*.py",
    "stats/__init__.py",
    "stats/*.py",
    "pyproject.toml",
    ".env.example",
    "tests/"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yyzybb537/remote_claude.git"
  },
  "keywords": [
    "claude",
    "cli",
    "terminal",
    "pty",
    "lark"
  ],
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
