{
  "name": "remote-claude",
  "version": "1.0.5-beta.2",
  "description": "双端共享 Claude CLI 工具",
  "bin": {
    "remote-claude": "bin/remote-claude",
    "cla": "bin/cla",
    "cl": "bin/cl",
    "cx": "bin/cx",
    "cdx": "bin/cdx"
  },
  "scripts": {
    "preinstall": "sh scripts/preinstall.sh",
    "postinstall": "sh scripts/install.sh --npm",
    "preuninstall": "sh scripts/uninstall.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "remote-claude"
    ]
  },
  "files": [
    "bin/",
    "scripts/*.sh",
    "scripts/*.py",
    "remote_claude.py",
    "server/*.py",
    "server/parsers/*.py",
    "client/*.py",
    "utils/*.py",
    "lark_client/__init__.py",
    "lark_client/*.py",
    "stats/__init__.py",
    "stats/*.py",
    "pyproject.toml",
    "uv.lock",
    "tests/",
    "resources/",
    ".npmrc"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yyzybb537/remote_claude.git"
  },
  "keywords": [
    "claude",
    "cli",
    "terminal",
    "pty",
    "lark"
  ],
  "bugs": {
    "url": "https://github.com/yyzybb537/remote_claude/issues"
  },
  "homepage": "https://github.com/yyzybb537/remote_claude#readme",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {}
}
